#!/bin/bash

set -e

#DEBHELPER#

. /etc/os-release

if [ "${ID}" = "pop" ]
then
    echo "system76-ubuntu-repo not needed on Pop"
    exit 0
fi

if [ -z "${UBUNTU_CODENAME}" ]
then
    echo "system76-ubuntu-repo only works on Ubuntu-based systems"
    exit 1
fi

